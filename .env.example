# wafpass-server — local development environment
# Copy to .env and source before running: `export $(grep -v '^#' .env | xargs)`
# For Docker Compose use the root .env.example instead (docker compose reads it automatically).

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL async DSN — consumed by SQLAlchemy (engine) and Alembic (migrations).
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://wafpass:changeme@localhost:5432/wafpass

# ── Server ────────────────────────────────────────────────────────────────────
# Environment label shown in logs and /health response.
WAFPASS_ENV=local

# Comma-separated CORS origins allowed to call the API.
# Include the Vite dev server (5173) when developing the dashboard locally.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Architect Sandbox ─────────────────────────────────────────────────────────
# Path to WAF++ control YAML files used by the /sandbox endpoint.
# When running the server from wafpass-server/ alongside the monorepo:
WAFPASS_CONTROLS_DIR=../pass/controls
